# Required
FSBO_DATABASE_URL=postgresql://user:pass@host:port/dbname
ADMIN_PASSWORD=your-admin-password

# Optional — enables AI photo analysis via Claude Haiku
ANTHROPIC_API_KEY=sk-ant-...

# Optional — residential proxy (IPRoyal primary, OxyLabs fallback)
IPROYAL_HOST=geo.iproyal.com
IPROYAL_PORT=11200
IPROYAL_USER=your-user
IPROYAL_PASS=your-pass

# Optional — OxyLabs Web Unblocker (fallback after 3 IPRoyal failures)
OXYLABS_USERNAME=your-username
OXYLABS_PASSWORD=your-password
# OXYLABS_HOST=unblock.oxylabs.io  (default)
# OXYLABS_PORT=60000                (default)

ENABLE_ZILLOW_FETCH=true
